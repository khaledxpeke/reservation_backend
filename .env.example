NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://user:password@localhost:5433/reservation_db?schema=public

# Set to false when Redis is not running (no refresh blacklist / slot locks).
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change-me-min-32-chars-random-secret
JWT_REFRESH_SECRET=change-me-min-32-chars-different-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Comma-separated allowed CORS origins (no trailing slash).
# Local + production front. Wildcards OK for Vercel previews: https://*.vercel.app
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app

# Or set your exact Vercel URL (also merged into CORS allowlist):
# FRONTEND_URL=https://your-app.vercel.app

# IANA timezone for “today” and hiding past slots (listing + booking). Default: Africa/Tunis
# APP_TIMEZONE=Africa/Tunis

# Used by Swagger UI "Try it out" server URL (no trailing slash)
PUBLIC_API_URL=http://localhost:4000
