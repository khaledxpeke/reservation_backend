generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PARTNER
  CUSTOMER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  PAID
}

enum FactureStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CategoryType {
  SPACE
  SERVICE
  ITEM
}

enum BookingUnit {
  MINUTES
  HOURS
  DAYS
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum GenderPreference {
  ANY
  MALE
  FEMALE
}

enum MatchPostStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  MATCH_REQUEST_RECEIVED
  MATCH_REQUEST_ACCEPTED
  MATCH_REQUEST_DECLINED
  MATCH_POST_CANCELLED
  MATCH_POST_FULL
  MATCH_POST_EXPIRED
}

enum SportType {
  PADEL
  TENNIS
  FOOTBALL
  BASKETBALL
  VOLLEYBALL
  OTHER
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  role      UserRole   @default(PARTNER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  partner           Partner?
  customerProfile   CustomerProfile?
  reservations      Reservation[]
  matchPosts        MatchPost[]        @relation("MatchPostCreator")
  matchJoinRequests MatchJoinRequest[] @relation("MatchJoinRequester")
  notifications     Notification[]

  @@map("users")
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String
  lastName  String
  gender    Gender
  /**
   * Date of birth (no time component).
   */
  dob       DateTime @db.Date
  phone     String
  /**
   * Tunisia governorate (wilaya) or other region label.
   */
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model Partner {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  logo        String?
  /**
   * Hero / banner image URL (HTTPS recommended)
   */
  coverImage  String?
  city        String
  /**
   * Tunisia governorate (wilaya) or other region label for location filters
   */
  governorate String?
  phone       String
  address     String?
  categoryId  String
  packId      String?
  isVerified  Boolean  @default(false)
  commissionPercent Decimal @default(0) @db.Decimal(5, 2)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category   @relation(fields: [categoryId], references: [id])
  pack      Pack?      @relation(fields: [packId], references: [id])
  resources Resource[]
  offers    Offer[]
  factures  ReservationFacture[]

  @@map("partners")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  /**
   * Card / listing image URL (HTTPS recommended)
   */
  imageUrl  String?
  createdAt DateTime @default(now())

  subCategories SubCategory[]
  partners      Partner[]

  @@map("categories")
}

model SubCategory {
  id                 String  @id @default(uuid())
  categoryId         String
  name               String
  defaultDurationMin Int
  /**
   * Optional illustration URL (e.g. Cloudinary)
   */
  imageUrl           String?

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  resources Resource[]

  @@unique([categoryId, name])
  @@map("sub_categories")
}

model Resource {
  id                 String       @id @default(uuid())
  partnerId          String
  name               String
  capacity           Int          @default(1)
  isActive           Boolean      @default(true)
  categoryType       CategoryType @default(SPACE)
  bookingUnit        BookingUnit  @default(MINUTES)
  minBookingDuration Int?
  maxBookingDuration Int?
  bufferTimeMin      Int          @default(0)
  /**
   * Optional: links court to a sub-category (e.g. Padel indoor).
   */
  subCategoryId      String?
  /**
   * Base price for the booking unit (MINUTES, HOURS, DAYS).
   */
  price              Decimal?     @db.Decimal(10, 2)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  partner        Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  subCategory    SubCategory?   @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  availabilities Availability[]
  reservations   Reservation[]

  @@unique([partnerId, name])
  @@map("resources")
}

model Availability {
  id              String    @id @default(uuid())
  resourceId      String
  dayOfWeek       DayOfWeek
  startTime       String // "HH:mm" format
  endTime         String // "HH:mm" format
  slotIntervalMin Int       @default(60)

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, dayOfWeek])
  @@map("availabilities")
}

model Reservation {
  id         String            @id @default(uuid())
  reference  String            @unique
  resourceId String
  /**
   * Optional link to a Customer account that placed the booking.
   * Null for anonymous guest bookings.
   */
  userId     String?
  guestName  String
  guestPhone String
  guestEmail String?
  date       DateTime          @db.Date
  endDate    DateTime?         @db.Date
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"
  status     ReservationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  facture  ReservationFacture?

  @@index([resourceId, date])
  @@index([userId])
  @@map("reservations")
}

model ReservationFacture {
  id                String        @id @default(uuid())
  reference         String        @unique
  reservationId     String        @unique
  partnerId         String
  reservationTotal  Decimal       @db.Decimal(10, 2)
  commissionPercent Decimal       @db.Decimal(5, 2)
  amountDue         Decimal       @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(10, 2)
  status            FactureStatus @default(UNPAID)
  generatedAt       DateTime      @default(now())
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  partner     Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, generatedAt])
  @@map("reservation_factures")
}

model Pack {
  id           String   @id @default(uuid())
  name         String   @unique
  maxResources Int
  features     Json     @default("[]")
  priceMonthly Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  partners Partner[]

  @@map("packs")
}

model MatchPost {
  id            String           @id @default(uuid())
  creatorId     String
  /**
   * Match date (YYYY-MM-DD).
   */
  date          DateTime         @db.Date
  startTime     String // "HH:mm"
  endTime       String // "HH:mm"
  governorate   String?
  city          String?
  /**
   * Number of additional players the creator is looking for.
   */
  neededPlayers Int
  sport         SportType        @default(PADEL)
  genderPref    GenderPreference @default(ANY)
  skillLevel    SkillLevel
  description   String?
  status        MatchPostStatus  @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  creator  User               @relation("MatchPostCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  requests MatchJoinRequest[]

  @@index([date, status])
  @@index([governorate, status])
  @@map("match_posts")
}

model MatchJoinRequest {
  id          String             @id @default(uuid())
  matchPostId String
  userId      String
  message     String?
  status      MatchRequestStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  matchPost MatchPost @relation(fields: [matchPostId], references: [id], onDelete: Cascade)
  user      User      @relation("MatchJoinRequester", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchPostId, userId])
  @@index([userId])
  @@map("match_join_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  /**
   * Optional link the user can follow when the notification is opened.
   */
  url       String?
  /**
   * Free-form metadata (e.g. matchPostId, requestId).
   */
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

enum OfferRecurrence {
  NONE
  DAILY
  WEEKDAY
  WEEKEND
  WEEKLY
}

model Offer {
  id              String          @id @default(uuid())
  partnerId       String
  title           String
  description     String?
  discountPercent Decimal         @db.Decimal(5, 2)
  validFrom       DateTime?
  validUntil      DateTime?
  recurrence      OfferRecurrence @default(NONE)
  recurrenceDays  String[]        @default([])
  timeStart       String?
  timeEnd         String?
  approvalStatus  ApprovalStatus  @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("offers")
}
